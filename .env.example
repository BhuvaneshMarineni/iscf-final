# Environment Variables for ISCF Website

# Next.js Configuration
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# API Configuration
# Add any API keys or external service configuration here
RESEND_API_KEY=
RESEND_FROM_EMAIL="ISCF Website <contact@iscf.global>"
RESEND_TO_EMAIL="Gopal@iscf.global"

# Example:
# NEXT_PUBLIC_API_URL=https://api.yourservice.com
# DATABASE_URL=your-database-connection-string
# SECRET_KEY=your-secret-key

# Note: NEXT_PUBLIC_ variables are exposed to the browser
# Keep sensitive data in server-only environment variables